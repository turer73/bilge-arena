# =============================================================================
# Bilge Arena VPS .env templates (REFERENCE ONLY - not loaded by docker-compose)
# =============================================================================
# Production env files yasaklidir bu repoda. VPS uzerinde
# /opt/bilge-arena/secrets/{db,postgrest,realtime}.env olarak yaratilir.
#
# Bu dosya sadece SHEMA dokumantasyonu icin var - hangi env var'lar gerekli.
# Production setup icin: scripts/deploy-vps.sh
# =============================================================================

# ---------- /opt/bilge-arena/secrets/db.env ----------
# Postgres role passwords (32-char base64, openssl rand -base64 24 ile uretilir)
APP_PWD=<random-32char-base64>
AUTH_PWD=<random-32char-base64>

# ---------- /opt/bilge-arena/secrets/postgrest.env ----------
# DB connection string (panola-network'te container DNS ile)
PGRST_DB_URI=postgres://bilge_arena_authenticator:<AUTH_PWD>@panola-postgres:5432/bilge_arena_dev
PGRST_DB_SCHEMAS=public
PGRST_DB_ANON_ROLE=anon
# JWKS asymmetric key fetch (Supabase 2024+ ES256 signing keys)
PGRST_JWT_SECRET={"jwks_url":"https://<supabase-project>.supabase.co/auth/v1/.well-known/jwks.json"}
PGRST_JWT_AUD=authenticated
PGRST_OPENAPI_MODE=ignore-privileges
PGRST_DB_USE_LEGACY_GUCS=false
PGRST_LOG_LEVEL=info

# ---------- /opt/bilge-arena/secrets/realtime.env ----------
# Realtime container env (Task 0.3'te uretilir)
DB_HOST=panola-postgres
DB_PORT=5432
DB_NAME=bilge_arena_dev
DB_USER=bilge_arena_authenticator
DB_PASSWORD=<AUTH_PWD>
DB_AFTER_CONNECT_QUERY=SET search_path TO _realtime
DB_ENC_KEY=<openssl rand -hex 16>
API_JWT_SECRET=<aynisi PGRST_JWT_SECRET>
SECRET_KEY_BASE=<openssl rand -hex 32>
ERL_AFLAGS=-proto_dist inet_tcp
DNS_NODES=
RLIMIT_NOFILE=10000
APP_NAME=bilge-arena-realtime
SEED_SELF_HOST=true
RUN_JANITOR=true
