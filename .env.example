# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Chat (Faz 7)
# ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis — Rate limiting (opsiyonel, yoksa in-memory fallback)
# Vercel entegrasyonu otomatik ekler (KV_REST_API_*), manuel icin UPSTASH_* kullan:
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...
# KV_REST_API_URL=https://xxx.upstash.io  (Vercel otomatik ekler)
# KV_REST_API_TOKEN=AXxx...               (Vercel otomatik ekler)

# Push Notifications (VAPID)
# npx web-push generate-vapid-keys ile uret
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=BLxx...
# VAPID_PRIVATE_KEY=xxx...
# VAPID_EMAIL=mailto:iletisim@bilgearena.com

# Resend — Email (haftalik ozet icin)
# RESEND_API_KEY=re_xxx...

# Cron Secret — Vercel Cron guvenlik token'i
# CRON_SECRET=random-secret-string

# Google AdSense
# NEXT_PUBLIC_ADSENSE_ID=ca-pub-xxxxxxxxxxxxx

# Sentry — https://sentry.io projesinden DSN al
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=bilge-arena
