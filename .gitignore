.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Build
dist/
build/
out/
tsconfig.tsbuildinfo

.vercel

# Soru bankasi veri dosyalari (full dataset DB'de, repo'da olmamali)
data/soru-bankasi/
wordquest/data/*
# Sample dosyasi istisna — dev seed testi icin gerekli (~20 soru)
!wordquest/data/questions-sample.json
# Private klasor — full dataset ve diger gizli assetler
/private/

# PWA build artifacts (auto-generated by next-pwa)
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map

# Playwright e2e artifacts
test-results/
playwright-report/
blob-report/
playwright/.cache/

# VPS infra secrets (DB passwords, JWT secrets, env files - VPS-only)
infra/vps/*/secrets/*.env
infra/vps/*/secrets/*.json
!infra/vps/*/secrets/.gitkeep
